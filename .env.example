# ============================================================
# AI RCA ASSISTANT - Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values below
#   3. NEVER commit .env to GitHub (it's in .gitignore)
# ============================================================

# ------------------------------------------------------------
# LLM PROVIDER — choose one: "groq" or "openai"
# ------------------------------------------------------------
LLM_PROVIDER=groq

# --- Groq (Free) ---
# Get key at: https://console.groq.com
GROQ_API_KEY=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
GROQ_MODEL=llama3-8b-8192

# --- OpenAI (Optional, paid) ---
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# --- Azure OpenAI (Optional, enterprise) ---
AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=your_deployment_name
AZURE_OPENAI_API_VERSION=2024-02-01

# ------------------------------------------------------------
# EMBEDDINGS — for ChromaDB vector search
# ------------------------------------------------------------
# "ollama"  = local, 100% free (requires Ollama installed)
# "openai"  = uses OpenAI embeddings (costs money)
# "huggingface" = free, runs locally (default)
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ------------------------------------------------------------
# DATABASE — PostgreSQL
# ------------------------------------------------------------
# Local Docker (default for development):
DATABASE_URL=postgresql://rca_user:rca_password@localhost:5432/rca_db

# Supabase (free cloud Postgres — use this for deployment):
# Get from: https://supabase.com → Project Settings → Database
# DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# ------------------------------------------------------------
# CHROMADB — Vector Database
# ------------------------------------------------------------
# Path where ChromaDB stores its data (inside Docker volume)
CHROMA_PERSIST_PATH=./chroma_data

# ------------------------------------------------------------
# APP SETTINGS
# ------------------------------------------------------------
APP_NAME=AI RCA Assistant
APP_VERSION=1.0.0
DEBUG=true
# For production on Render/Railway, set to false
